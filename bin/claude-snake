#!/usr/bin/env bash
# Convenience launcher: start Claude Code inside tmux with snake-friendly
# pane switching. The claude-snake plugin creates the game pane itself on
# SessionStart, so this only sets up tmux + handy keybindings.
#
# Usage: claude-snake [args passed through to `claude`]
set -euo pipefail

if [ -n "${TMUX:-}" ]; then
  # Already inside tmux — the plugin will handle the pane. Just run Claude.
  exec claude "$@"
fi

if ! command -v tmux >/dev/null 2>&1; then
  echo "claude-snake needs tmux (brew install tmux)." >&2
  exit 1
fi

session="claude-snake-$$"

# Alt-Left / Alt-Right switch panes without the tmux prefix (server-global).
tmux bind-key -n M-Left  select-pane -L >/dev/null 2>&1 || true
tmux bind-key -n M-Right select-pane -R >/dev/null 2>&1 || true

tmux new-session -d -s "$session" "claude $*"
exec tmux attach-session -t "$session"
